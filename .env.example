# RAGFlow API Configuration
# Copy this file to .env and fill in your values

# RAGFlow Server URL
# Examples: http://127.0.0.1, http://localhost:80, https://ragflow.example.com
RAGFLOW_API_URL=http://127.0.0.1

# RAGFlow API Key
# Get this from: RAGFlow Console → Profile → API
RAGFLOW_API_KEY=ragflow-xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# Dataset IDs to search (optional)
# Leave empty to search all datasets, or specify specific ones:
# RAGFLOW_DATASET_IDS=["dataset-id-1", "dataset-id-2", "dataset-id-3"]
RAGFLOW_DATASET_IDS=

# Maximum results to return (optional, default: 5)
RAGFLOW_TOP_K=5

# Similarity threshold (optional, 0-1, default: RAGFlow API default)
# Lower values = more results but less relevant
# RAGFLOW_SIMILARITY_THRESHOLD=0.1
